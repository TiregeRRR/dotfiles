def reload_runtime() -> None:
    if shutil.which("hyprctl"):
        subprocess.run(["hyprctl", "reload"], check=False)

    if shutil.which("dunstctl"):
        subprocess.run(
            ["dunstctl", "reload", str(DUNST_OUT)],
            check=False,
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
        )
    elif shutil.which("dunst"):
        subprocess.run(["pkill", "dunst"], check=False)
        subprocess.Popen(
            ["dunst", "-config", str(DUNST_OUT)],
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
            start_new_session=True,
        )

    if not os.environ.get("WAYLAND_DISPLAY"):
        return

    if shutil.which("hyprpaper"):
        subprocess.run(["pkill", "hyprpaper"], check=False)
        subprocess.Popen(
            ["hyprpaper", "-c", str(HYPRPAPER_OUT)],
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
            start_new_session=True,
        )

    if shutil.which("waybar"):
        subprocess.run(["pkill", "waybar"], check=False)
        subprocess.Popen(
            ["waybar", "-c", str(WAYBAR_JSON_OUT), "-s", str(WAYBAR_CSS_OUT)],
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
            start_new_session=True,
        )

    if shutil.which("notify-send"):
        theme_id = current_theme_id()
        subprocess.run(
            ["notify-send", "Theme applied", theme_id],
            check=False,
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
        )


def apply_theme(theme_name: str, no_reload: bool) -> None:
    theme = load_theme(theme_name)
    context = build_context(theme_name, theme)

    write_file(HYPR_THEME_OUT, render("hypr-colors.conf.tpl", context))
    write_file(WAYBAR_JSON_OUT, render("waybar.jsonc.tpl", context))
    write_file(WAYBAR_CSS_OUT, render("waybar.css.tpl", context))
    write_file(HYPRLOCK_OUT, render("hyprlock.conf.tpl", context))
    write_file(HYPRPAPER_OUT, render("hyprpaper.conf.tpl", context))
    write_file(ROFI_THEME_OUT, render("rofi-theme.rasi.tpl", context))
    write_file(ALACRITTY_THEME_OUT, render("alacritty-theme.toml.tpl", context))
    write_file(ALACRITTY_FONT_OUT, render("alacritty-font.toml.tpl", context))
    write_file(NVIM_THEME_OUT, render("nvim-theme.lua.tpl", context))
    write_file(DUNST_OUT, render("dunstrc.tpl", context))
    apply_btop_theme(context)
    apply_k9s_theme(context)
    apply_vscode_theme(theme, context)
    write_file(CURRENT_THEME_FILE, f"{theme_name}\n")

    for profile in firefox_profiles():
        chrome_dir = profile / "chrome"
        chrome_dir.mkdir(parents=True, exist_ok=True)

        write_file(chrome_dir / "theme-switcher-userChrome.css", render("firefox-userChrome.css.tpl", context))
        write_file(chrome_dir / "theme-switcher-userContent.css", render("firefox-userContent.css.tpl", context))

        user_chrome_import = '@import url("theme-switcher-userChrome.css");'
        user_content_import = '@import url("theme-switcher-userContent.css");'

        user_chrome_path = chrome_dir / "userChrome.css"
        user_content_path = chrome_dir / "userContent.css"
        user_js_path = profile / "user.js"

        user_chrome_content = user_chrome_path.read_text() if user_chrome_path.exists() else ""
        user_content_existing = user_content_path.read_text() if user_content_path.exists() else ""
        user_js_existing = user_js_path.read_text() if user_js_path.exists() else ""

        write_file(
            user_chrome_path,
            replace_or_append_block(user_chrome_content, USER_CHROME_MARKER_BEGIN, USER_CHROME_MARKER_END, user_chrome_import),
        )
        write_file(
            user_content_path,
            replace_or_append_block(user_content_existing, USER_CHROME_MARKER_BEGIN, USER_CHROME_MARKER_END, user_content_import),
        )
        write_file(
            user_js_path,
            replace_or_append_block(
                user_js_existing,
                USER_JS_MARKER_BEGIN,
                USER_JS_MARKER_END,
                '\n'.join(
                    [
                        'user_pref("toolkit.legacyUserProfileCustomizations.stylesheets", true);',
                        'user_pref("browser.in-content.dark-mode", true);',
                        'user_pref("widget.content.allow-gtk-dark-theme", true);',
                        'user_pref("devtools.theme", "dark");',
                    ]
                ),
            ),
        )

    if not no_reload:
        reload_runtime()


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(description="Apply a desktop theme across Hyprland, Waybar, Rofi and Hyprlock.")
    parser.add_argument("theme", nargs="?", help="Theme id to apply")
    parser.add_argument("--list", action="store_true", help="List available theme ids")
    parser.add_argument("--current", action="store_true", help="Apply the current saved theme")
    parser.add_argument("--current-name", action="store_true", help="Print the current saved theme id")
    parser.add_argument("--no-reload", action="store_true", help="Generate files without reloading running programs")
    return parser.parse_args()


def main() -> int:
    args = parse_args()

    if args.list:
        print("\n".join(list_themes()))
        return 0

    if args.current_name:
        print(current_theme_id())
        return 0

    if args.current:
        theme_name = current_theme_id()
        apply_theme(theme_name, args.no_reload)
        return 0

    theme_name = args.theme or current_theme_id()
    available = list_themes()
    if theme_name not in available:
        print(f"Unknown theme '{theme_name}'. Available: {', '.join(available)}", file=sys.stderr)
        return 1

    apply_theme(theme_name, args.no_reload)
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
