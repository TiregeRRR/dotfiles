def apply_btop_theme(context: dict[str, str]) -> None:
    write_file(BTOP_THEME_OUT, render("btop.theme.tpl", context))
    existing = BTOP_CONF_OUT.read_text() if BTOP_CONF_OUT.exists() else ""
    updated = replace_setting_line(existing, "color_theme", '"theme-switcher"')
    write_file(BTOP_CONF_OUT, updated)


def apply_k9s_theme(context: dict[str, str]) -> None:
    write_file(K9S_SKIN_OUT, render("k9s-skin.yaml.tpl", context))

    existing = K9S_CONFIG_OUT.read_text() if K9S_CONFIG_OUT.exists() else ""
    skin_line = f"skin: {K9S_SKIN_NAME}"

    if re.search(r"(?m)^\s*skin:\s*.*$", existing):
        updated = re.sub(r"(?m)^(\s*)skin:\s*.*$", rf"\1{skin_line}", existing, count=1)
    elif re.search(r"(?m)^(\s*)ui:\s*$", existing):
        updated = re.sub(r"(?m)^(\s*)ui:\s*$", rf"\g<0>\n\1  {skin_line}", existing, count=1)
    elif re.search(r"(?m)^k9s:\s*$", existing):
        updated = re.sub(r"(?m)^k9s:\s*$", f"k9s:\n  ui:\n    {skin_line}", existing, count=1)
    else:
        updated = f"k9s:\n  ui:\n    {skin_line}\n"

    write_file(K9S_CONFIG_OUT, updated)


def build_context(theme_name: str, theme: dict[str, str]) -> dict[str, str]:
    background = hex_value(theme["background"])
    background_alt = hex_value(theme["background_alt"])
    foreground = hex_value(theme["foreground"])
    accent = hex_value(theme["accent"])
    accent_alt = hex_value(theme["accent_alt"])
    warning = hex_value(theme["warning"])
    danger = hex_value(theme["danger"])
    muted = hex_value(theme["muted"])
    wallpaper = resolve_wallpaper_path(theme["wallpaper"])
    fonts = resolve_fonts(theme)
    nvim_colorscheme = theme.get("nvim_colorscheme", "tokyonight-night")
    alacritty = theme["alacritty"]

