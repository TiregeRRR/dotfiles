def hex_value(value: str) -> str:
    return value.strip().lstrip("#").lower()


def css_hex(value: str) -> str:
    return f"#{hex_value(value)}"


def rgba(value: str, alpha: float) -> str:
    raw = hex_value(value)
    r = int(raw[0:2], 16)
    g = int(raw[2:4], 16)
    b = int(raw[4:6], 16)
    return f"rgba({r}, {g}, {b}, {alpha:.2f})"


def hypr_rgb(value: str) -> str:
    return f"rgb({hex_value(value)})"


def css_hex_alpha(value: str, alpha: str) -> str:
    return f"#{hex_value(value)}{alpha.lower()}"


def list_themes() -> list[str]:
    return sorted(path.stem for path in THEMES_DIR.glob("*.json"))


def load_theme(theme_name: str) -> dict[str, str]:
    theme_path = THEMES_DIR / f"{theme_name}.json"
    if not theme_path.exists():
        raise FileNotFoundError(f"Theme '{theme_name}' does not exist: {theme_path}")
    return json.loads(theme_path.read_text())


def list_fonts() -> list[str]:
    return sorted(path.stem for path in FONTS_DIR.glob("*.json"))


def load_font(font_name: str) -> dict:
    font_path = FONTS_DIR / f"{font_name}.json"
    if not font_path.exists():
        raise FileNotFoundError(f"Font preset '{font_name}' does not exist: {font_path}")
    return json.loads(font_path.read_text())


def resolve_wallpaper_path(value: str) -> str:
    path = Path(value).expanduser()
    if not path.is_absolute():
        path = (BASE_DIR / path).resolve()
    else:
        path = path.resolve()

    if not path.exists():
        raise FileNotFoundError(f"Wallpaper file does not exist: {path}")

    return str(path)


def render(template_name: str, context: dict[str, str]) -> str:
    template = (TEMPLATES_DIR / template_name).read_text()
    rendered = template
    for key, value in sorted(context.items(), key=lambda item: len(item[0]), reverse=True):
        rendered = rendered.replace(f"__{key.upper()}__", value)
    return rendered


def write_file(path: Path, content: str) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(content)


def read_text_file(path: Path) -> str | None:
    if not path.exists():
        return None

    value = path.read_text().strip()
    return value or None


def read_default(path: Path, fallback: str) -> str:
    return read_text_file(path) or fallback


def read_saved_value(path: Path, legacy_path: Path, default_value: str) -> str:
    current = read_text_file(path)
    if current:
        return current

    legacy = read_text_file(legacy_path)
    if legacy:
        write_file(path, f"{legacy}\n")
        return legacy

    return default_value


def default_theme_id() -> str:
    return read_default(DEFAULT_THEME_FILE, FALLBACK_THEME_ID)


def default_font_id() -> str:
    return read_default(DEFAULT_FONT_FILE, FALLBACK_FONT_ID)


def current_theme_id() -> str:
    return read_saved_value(CURRENT_THEME_FILE, LEGACY_CURRENT_THEME_FILE, default_theme_id())


def current_font_id() -> str:
    return read_saved_value(CURRENT_FONT_FILE, LEGACY_CURRENT_FONT_FILE, default_font_id())


def replace_or_append_block(content: str, begin: str, end: str, block: str) -> str:
    replacement = f"{begin}\n{block.rstrip()}\n{end}\n"
    if begin in content and end in content:
        start = content.index(begin)
        finish = content.index(end, start) + len(end)
        trailing_newline = "\n" if finish < len(content) and content[finish] == "\n" else ""
        return f"{content[:start].rstrip()}\n{replacement}{trailing_newline}{content[finish + len(trailing_newline):].lstrip()}"

    if content and not content.endswith("\n"):
        content += "\n"

    return f"{content}{replacement}"


def replace_setting_line(content: str, key: str, value: str) -> str:
    line = f'{key} = {value}'
    pattern = rf"(?m)^{re.escape(key)}\s*=.*$"
    if re.search(pattern, content):
        return re.sub(pattern, line, content, count=1)

    if content and not content.endswith("\n"):
        content += "\n"

    return f"{content}{line}\n"


def load_json(path: Path) -> dict:
    if not path.exists():
        return {}

    raw = path.read_text().strip()
    if not raw:
        return {}

    return json.loads(raw)


def write_json(path: Path, content: dict) -> None:
    write_file(path, json.dumps(content, indent=4, ensure_ascii=False) + "\n")


def resolve_fonts(theme: dict) -> dict[str, str]:
    font_id = current_font_id()
    available = set(list_fonts())
    font_preset = {}

    if font_id in available:
        font_preset = load_font(font_id)
    else:
        font_id = default_font_id()
        if font_id in available:
            font_preset = load_font(font_id)

    font_ui = font_preset.get("font_ui", theme.get("font_ui", "Noto Sans"))
    font_mono = font_preset.get("font_mono", theme.get("font_mono", "JetBrains Mono"))
    font_nerd = font_preset.get("font_nerd", theme.get("font_nerd", font_mono))

    return {
        "font_id": font_id,
        "font_name": font_preset.get("name", font_id),
        "font_ui": font_ui,
        "font_mono": font_mono,
        "font_nerd": font_nerd,
        "font_waybar_size": str(font_preset.get("waybar_size", 11)),
        "font_rofi_size": str(font_preset.get("rofi_size", 11)),
        "font_alacritty_size": str(font_preset.get("alacritty_size", 10)),
        "font_hypr_groupbar_size": str(font_preset.get("hypr_groupbar_size", 10)),
        "font_nvim_gui_size": str(font_preset.get("nvim_gui_size", 11)),
    }


def firefox_profiles() -> list[Path]:
    if not FIREFOX_PROFILES_INI.exists():
        return []

    import configparser

    parser = configparser.RawConfigParser()
    parser.read(FIREFOX_PROFILES_INI)
    profiles: list[Path] = []

    def resolve(path_value: str, is_relative: str) -> Path:
        path = Path(path_value)
        if is_relative == "1":
            path = FIREFOX_PROFILES_INI.parent / path
        return path.resolve()

    for section in parser.sections():
        if section.startswith("Profile"):
            path_value = parser.get(section, "Path", fallback="")
            if not path_value:
                continue
            profile = resolve(path_value, parser.get(section, "IsRelative", fallback="1"))
            if profile.exists():
                profiles.append(profile)
        elif section.startswith("Install"):
            path_value = parser.get(section, "Default", fallback="")
            if not path_value:
                continue
            profile = resolve(path_value, "1")
            if profile.exists():
                profiles.append(profile)

    unique: list[Path] = []
    seen = set()
    for profile in profiles:
        if profile not in seen:
            unique.append(profile)
            seen.add(profile)

    return unique


def vscode_settings_paths() -> list[Path]:
    return [path for path in VSCODE_SETTINGS_PATHS if path.parent.exists() or path.exists()]


