#!/usr/bin/env bash
set -euo pipefail

STATE_ROOT="${XDG_STATE_HOME:-$HOME/.local/state}"
MONITORS_FILE="$STATE_ROOT/hypr/monitors.conf"

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
  cat <<'EOF'
Usage: monitor-setup

Launches nwg-displays and saves monitor rules to ~/.local/state/hypr/monitors.conf.
EOF
  exit 0
fi

if (( $# > 0 )); then
  printf 'monitor-setup does not accept arguments.\n' >&2
  exit 1
fi

mkdir -p "$(dirname "$MONITORS_FILE")"
touch "$MONITORS_FILE"

if ! command -v nwg-displays >/dev/null 2>&1; then
  printf 'nwg-displays is not installed.\n' >&2
  exit 1
fi

exec nwg-displays -m "$MONITORS_FILE"
