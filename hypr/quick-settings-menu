#!/usr/bin/env bash
set -euo pipefail

CONFIG_HOME="${XDG_CONFIG_HOME:-$HOME/.config}"
STATE_HOME="${XDG_STATE_HOME:-$HOME/.local/state}"
THEME_BASE="$CONFIG_HOME/theme-switcher"
STATE_DIR="$STATE_HOME/theme-switcher"
THEMES_DIR="$THEME_BASE/themes"
FONTS_DIR="$THEME_BASE/fonts"
ROFI_THEME_FILE="$CONFIG_HOME/rofi/theme-generated.rasi"
DEFAULT_THEME_ID="tokyonight"
DEFAULT_FONT_ID="pixel-code"

read_trimmed_file() {
    local path="$1"
    local value

    [[ -f "$path" ]] || return 1

    value=$(<"$path")
    value="${value//$'\n'/}"
    [[ -n "$value" ]] || return 1

    printf '%s\n' "$value"
}

resolve_theme_id() {
    read_trimmed_file "$STATE_DIR/current_theme" \
        || read_trimmed_file "$THEME_BASE/default_theme" \
        || printf '%s\n' "$DEFAULT_THEME_ID"
}

resolve_font_id() {
    read_trimmed_file "$STATE_DIR/current_font" \
        || read_trimmed_file "$THEME_BASE/default_font" \
        || printf '%s\n' "$DEFAULT_FONT_ID"
}

json_value() {
    local file="$1"
    local filter="$2"
    local fallback="$3"
    local value=""

    if [[ -n "$file" && -f "$file" ]]; then
        value=$(jq -r "$filter // empty" "$file" 2>/dev/null || true)
    fi

    if [[ -n "$value" && "$value" != "null" ]]; then
        printf '%s\n' "$value"
        return
    fi

    printf '%s\n' "$fallback"
}

current_theme_id="$(resolve_theme_id)"
theme_file="$THEMES_DIR/$current_theme_id.json"
if [[ ! -f "$theme_file" ]]; then
    current_theme_id="$DEFAULT_THEME_ID"
    theme_file="$THEMES_DIR/$current_theme_id.json"
fi

current_font_id="$(resolve_font_id)"
font_file="$FONTS_DIR/$current_font_id.json"
if [[ ! -f "$font_file" ]]; then
    font_file=""
fi

theme_name="$(json_value "$theme_file" '.name' "$current_theme_id")"
font_name="$(json_value "$font_file" '.name' "$current_font_id")"
font_mono="$(json_value "$font_file" '.font_mono' "$(json_value "$theme_file" '.font_mono' "JetBrains Mono Nerd Font")")"
font_rofi_size="$(json_value "$font_file" '.rofi_size' '11')"

background="#$(json_value "$theme_file" '.background' '1a1b26')"
background_alt="#$(json_value "$theme_file" '.background_alt' '16161e')"
foreground="#$(json_value "$theme_file" '.foreground' 'c0caf5')"
accent="#$(json_value "$theme_file" '.accent' '7aa2f7')"
accent_alt="#$(json_value "$theme_file" '.accent_alt' '7aa2f7')"
warning="#$(json_value "$theme_file" '.warning' 'e0af68')"
muted="#$(json_value "$theme_file" '.muted' '565f89')"

if [[ "${1:-}" == "--label" ]]; then
    printf 'CTL\n'
    exit 0
fi

truncate_text() {
    local value="$1"
    local limit="$2"

    if (( ${#value} <= limit )); then
        printf '%s\n' "$value"
        return
    fi

    printf '%s...\n' "${value:0:limit-3}"
}

have_wifi_device() {
    nmcli -t -f DEVICE,TYPE device status 2>/dev/null | awk -F: '$2 == "wifi" { found = 1 } END { exit found ? 0 : 1 }'
}

wifi_summary() {
    local radio ssid

    if ! have_wifi_device; then
        printf 'unavailable\n'
        return
    fi

    radio="$(nmcli radio wifi 2>/dev/null || true)"
    if [[ "$radio" != "enabled" ]]; then
        printf 'disabled\n'
        return
    fi

    ssid="$(nmcli -t -f ACTIVE,SSID dev wifi list 2>/dev/null | awk -F: '$1 == "yes" { print $2; exit }')"
    if [[ -n "$ssid" ]]; then
        truncate_text "enabled  $ssid" 26
        return
    fi

    printf 'enabled  no-link\n'
}

read_wpctl_state() {
    local target="$1"
    local raw volume muted

    raw="$(wpctl get-volume "$target" 2>/dev/null || true)"
    volume="$(awk '{ if (NF >= 2) { printf "%d", ($2 * 100) + 0.5 } }' <<<"$raw")"
    muted="no"

    if [[ "$raw" == *"[MUTED]"* ]]; then
        muted="yes"
    fi

    if [[ -z "$volume" ]]; then
        volume="0"
    fi

    printf '%s|%s\n' "$volume" "$muted"
}

sink_summary() {
    local state volume muted

    state="$(read_wpctl_state "@DEFAULT_AUDIO_SINK@")"
    volume="${state%%|*}"
    muted="${state##*|}"

    if [[ "$muted" == "yes" ]]; then
        printf '%s%% muted\n' "$volume"
        return
    fi

    printf '%s%% live\n' "$volume"
}

source_summary() {
    local state volume muted

    state="$(read_wpctl_state "@DEFAULT_AUDIO_SOURCE@")"
    volume="${state%%|*}"
    muted="${state##*|}"

    if [[ "$muted" == "yes" ]]; then
        printf '%s%% muted\n' "$volume"
        return
    fi

    printf '%s%% hot\n' "$volume"
}

have_player() {
    command -v playerctl >/dev/null 2>&1 && playerctl -p playerctld status >/dev/null 2>&1
}

player_summary() {
    local status artist title summary

    status="$(playerctl -p playerctld status 2>/dev/null | tr '[:upper:]' '[:lower:]')"
    artist="$(playerctl -p playerctld metadata artist 2>/dev/null || true)"
    title="$(playerctl -p playerctld metadata title 2>/dev/null || true)"

    summary="$status"
    if [[ -n "$artist" || -n "$title" ]]; then
        summary="$summary  ${artist:+$artist - }$title"
    fi

    truncate_text "$summary" 26
}

format_row() {
    local section="$1"
    local action="$2"
    local detail="${3:-}"

    if [[ -n "$detail" ]]; then
        printf '%-6s %-18s %s' "$section" "$action" "$detail"
        return
    fi

    printf '%-6s %s' "$section" "$action"
}

build_rows() {
    local -n out_rows="$1"
    local -n out_actions="$2"

    out_rows=()
    out_actions=()

    out_rows+=("$(format_row "WIFI" "toggle radio" "$(wifi_summary)")")
    out_actions+=("toggle_wifi")

    out_rows+=("$(format_row "WIFI" "open editor" "NetworkManager")")
    out_actions+=("open_network_editor")

    out_rows+=("$(format_row "VOL" "mute or unmute" "$(sink_summary)")")
    out_actions+=("toggle_sink_mute")

    out_rows+=("$(format_row "VOL" "louder" "+5%")")
    out_actions+=("volume_up")

    out_rows+=("$(format_row "VOL" "quieter" "-5%")")
    out_actions+=("volume_down")

    out_rows+=("$(format_row "VOL" "open mixer" "pavucontrol")")
    out_actions+=("open_mixer")

    out_rows+=("$(format_row "MIC" "toggle input" "$(source_summary)")")
    out_actions+=("toggle_source_mute")

    if have_player; then
        out_rows+=("$(format_row "PLAY" "play or pause" "$(player_summary)")")
        out_actions+=("toggle_playback")

        out_rows+=("$(format_row "PLAY" "previous track")")
        out_actions+=("play_previous")

        out_rows+=("$(format_row "PLAY" "next track")")
        out_actions+=("play_next")
    fi

    out_rows+=("$(format_row "THEME" "switch theme" "$theme_name")")
    out_actions+=("switch_theme")

    out_rows+=("$(format_row "FONT" "switch font" "$font_name")")
    out_actions+=("switch_font")

    out_rows+=("$(format_row "MON" "configure outputs" "nwg-displays")")
    out_actions+=("open_monitor_setup")

    out_rows+=("$(format_row "LOCK" "lock screen")")
    out_actions+=("lock_screen")
}

fallback_rofi_theme() {
    cat <<EOF
* {
    bg: ${background};
    bg-alt: ${background_alt};
    fg: ${foreground};
    accent: ${accent};
    accent-alt: ${accent_alt};
    warning: ${warning};
    muted: ${muted};
    background-color: transparent;
    text-color: @fg;
    font: "${font_mono} ${font_rofi_size}";
}

window {
    width: 460px;
    location: southeast;
    anchor: southeast;
    x-offset: -14px;
    y-offset: -38px;
    transparency: "real";
    border: 2px;
    border-radius: 0px;
    border-color: @accent;
    background-color: @bg;
    children: [ mainbox ];
}

mainbox {
    spacing: 0px;
    background-color: transparent;
    children: [ message, listview ];
}

message {
    padding: 10px 14px;
    border: 0px 0px 1px 0px;
    border-color: @accent;
    background-color: @bg;
    text-color: @accent;
}

textbox {
    background-color: inherit;
    text-color: inherit;
}

listview {
    padding: 6px 0px;
    lines: 14;
    columns: 1;
    dynamic: true;
    fixed-height: false;
    scrollbar: false;
    background-color: @bg;
    border: 0px;
}

element {
    padding: 8px 14px;
    border-radius: 0px;
    background-color: transparent;
    text-color: @fg;
}

element normal.normal,
element alternate.normal {
    background-color: transparent;
    text-color: @fg;
}

element normal.active,
element alternate.active {
    background-color: transparent;
    text-color: @accent-alt;
}

element normal.urgent,
element alternate.urgent {
    background-color: transparent;
    text-color: @warning;
}

element selected.normal {
    background-color: @accent;
    text-color: @bg-alt;
}

element selected.active {
    background-color: @accent-alt;
    text-color: @bg-alt;
}

element selected.urgent {
    background-color: @warning;
    text-color: @bg-alt;
}

element-text, element-icon {
    background-color: inherit;
    text-color: inherit;
}
EOF
}

rofi_theme() {
    if [[ -f "$ROFI_THEME_FILE" ]]; then
        cat <<EOF
@import "${ROFI_THEME_FILE}"

window {
    width: 460px;
    location: southeast;
    anchor: southeast;
    x-offset: -14px;
    y-offset: -38px;
    transparency: "real";
    border: 2px;
    border-radius: 0px;
    border-color: @accent;
    background-color: @bg;
    children: [ mainbox ];
}

mainbox {
    spacing: 0px;
    background-color: transparent;
    children: [ message, listview ];
}

message {
    padding: 10px 14px;
    border: 0px 0px 1px 0px;
    border-color: @accent;
    background-color: @bg;
    text-color: @accent;
}

textbox {
    background-color: inherit;
    text-color: inherit;
}

listview {
    padding: 6px 0px;
    lines: 14;
    columns: 1;
    dynamic: true;
    fixed-height: false;
    scrollbar: false;
    background-color: @bg;
    border: 0px;
    border-radius: 0px;
}

element {
    padding: 8px 14px;
    border-radius: 0px;
    background-color: transparent;
    text-color: @fg;
}

element normal.normal,
element alternate.normal {
    background-color: transparent;
    text-color: @fg;
}

element normal.active,
element alternate.active {
    background-color: transparent;
    text-color: @accent-alt;
}

element normal.urgent,
element alternate.urgent {
    background-color: transparent;
    text-color: @warning;
}

element selected.normal {
    background-color: @accent;
    text-color: @bg-alt;
}

element selected.active {
    background-color: @accent-alt;
    text-color: @bg-alt;
}

element selected.urgent {
    background-color: @warning;
    text-color: @bg-alt;
}

element-text, element-icon {
    background-color: inherit;
    text-color: inherit;
}
EOF
        return
    fi

    fallback_rofi_theme
}

show_menu() {
    local -a rows actions
    local choice

    build_rows rows actions

    choice="$(
        printf '%s\n' "${rows[@]}" \
            | rofi \
                -no-config \
                -monitor -1 \
                -dmenu \
                -i \
                -no-custom \
                -format i \
                -mesg "quick settings  ${theme_name}" \
                -theme-str "$(rofi_theme)"
    )"

    if [[ -z "$choice" ]]; then
        return 1
    fi

    printf '%s\n' "${actions[$choice]}"
}

run_action() {
    local action="$1"

    case "$action" in
        toggle_wifi)
            if have_wifi_device; then
                if [[ "$(nmcli radio wifi 2>/dev/null || true)" == "enabled" ]]; then
                    nmcli radio wifi off >/dev/null 2>&1 || true
                else
                    nmcli radio wifi on >/dev/null 2>&1 || true
                fi
            fi
            ;;
        open_network_editor)
            exec nm-connection-editor
            ;;
        toggle_sink_mute)
            wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle >/dev/null 2>&1 || true
            ;;
        volume_up)
            wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%+ >/dev/null 2>&1 || true
            ;;
        volume_down)
            wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%- >/dev/null 2>&1 || true
            ;;
        open_mixer)
            exec pavucontrol
            ;;
        open_monitor_setup)
            exec ~/.config/hypr/monitor-setup
            ;;
        toggle_source_mute)
            wpctl set-mute @DEFAULT_AUDIO_SOURCE@ toggle >/dev/null 2>&1 || true
            ;;
        toggle_playback)
            playerctl -p playerctld play-pause >/dev/null 2>&1 || true
            ;;
        play_previous)
            playerctl -p playerctld previous >/dev/null 2>&1 || true
            ;;
        play_next)
            playerctl -p playerctld next >/dev/null 2>&1 || true
            ;;
        switch_theme)
            exec "$THEME_BASE/theme-menu"
            ;;
        switch_font)
            exec "$THEME_BASE/font-menu"
            ;;
        lock_screen)
            exec hyprlock --immediate-render --config "$CONFIG_HOME/hypr/hyprlock.conf"
            ;;
    esac
}

while true; do
    selected_action="$(show_menu)" || exit 0
    run_action "$selected_action"
done
